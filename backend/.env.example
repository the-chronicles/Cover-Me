# ============================================================================
# CoverMe Backend — Production Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in your production values.
# NEVER commit .env to version control.
# ============================================================================

# ─── Core Security ───────────────────────────────────────────────────────────

# REQUIRED: A strong random string for JWT token signing (min 32 chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# Optional: Separate key for encrypting GPS coordinates at rest (32-byte Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, derives from JWT_SECRET_KEY automatically.
LOCATION_ENCRYPTION_KEY=

# ─── Database ────────────────────────────────────────────────────────────────

# For local development (SQLite — single-user only):
# DATABASE_URL=sqlite:///./coverme.db

# For production (PostgreSQL — required for concurrent users):
DATABASE_URL=postgresql://username:password@host:5432/coverme_db

# ─── Redis (Caching & Rate Limiting) ────────────────────────────────────────

# Managed Redis instance URL (Render, Railway, Upstash, etc.)
# If not set, rate limiting uses in-memory storage (resets on restart).
REDIS_URL=redis://default:password@redis-host:6379

# ─── SMS Gateway (Termii — Nigeria Routing) ─────────────────────────────────

TERMII_API_KEY=YOUR_TERMII_API_KEY
TERMII_SENDER_ID=YOUR_APPROVED_SENDER_ID

# ─── WhatsApp Business API (Meta Cloud API) ─────────────────────────────────

META_WA_ACCESS_TOKEN=YOUR_META_PERMANENT_SYSTEM_USER_TOKEN
META_WA_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID
META_WA_TEMPLATE_LANGUAGE=en_US # Change to your template's language code (e.g. en, en_GB, en_US)

# ─── Object Storage (Vehicle Photos) ────────────────────────────────────────

# Cloudflare R2 or AWS S3 bucket configuration
# If not set, photos save to local filesystem (static/uploads/)
S3_BUCKET_NAME=coverme-photos
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_PUBLIC_URL_PREFIX=https://storage.coverme.ng

# ─── Admin Dashboard ────────────────────────────────────────────────────────

# Admin panel login credentials (accessible at /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
ADMIN_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# ─── Tesseract OCR ──────────────────────────────────────────────────────────

# Leave blank if tesseract is on PATH (Docker image includes it)
TESSERACT_CMD_PATH=
