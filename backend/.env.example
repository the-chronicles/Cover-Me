# CoverMe Environment Configuration Template

# FastAPI Authentication Secret
JWT_SECRET_KEY=coverme-super-safety-secret-key-1092837

# Database Connection URL (SQLite default)
# For production: postgresql://username:password@localhost:5432/covermedb
DATABASE_URL=sqlite:///./coverme.db

# --- Termii SMS API Integration (Nigeria Routing) ---
TERMII_API_KEY=YOUR_TERMII_API_KEY
TERMII_SENDER_ID=YOUR_REGISTERED_SENDER_ID

# --- Meta WhatsApp Cloud API Integration ---
META_WA_ACCESS_TOKEN=YOUR_META_WA_ACCESS_TOKEN
META_WA_PHONE_NUMBER_ID=YOUR_META_WA_PHONE_NUMBER_ID

# --- Tesseract OCR Configuration ---
# Leave blank if 'tesseract' is globally available in your environment path
# For Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# For macOS: /opt/homebrew/bin/tesseract
TESSERACT_CMD_PATH=
