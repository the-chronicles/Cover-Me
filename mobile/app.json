{
  "expo": {
    "name": "CoverMe",
    "slug": "coverme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coverme",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CoverMe needs your location to update your trusted circle and emergency services during an active journey or SOS trigger.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CoverMe requires background location access to keep your trusted contacts informed of your safety during your journey even when the app is in the background.",
        "NSCameraUsageDescription": "CoverMe needs camera access to capture your vehicle's license plate for verification.",
        "NSMicrophoneUsageDescription": "CoverMe needs microphone access for hands-free voice-activated SOS triggers."
      },
      "bundleIdentifier": "com.chroniclesmaan.coverme"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "CAMERA",
        "SEND_SMS"
      ],
      "package": "com.chroniclesmaan.coverme",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyATBfXKoyWbtvySWJqVcLv_7yls5MXq3Kk"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563EB",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be750cf4-c4ea-484f-8c45-1ead7d145a3e"
      }
    }
  }
}